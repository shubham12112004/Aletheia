# Aletheia Frontend Environment Variables

# The base URL of your deployed backend service (e.g., http://localhost:5000 for local dev)
VITE_API_URL=http://localhost:5000

# Cloudflare Turnstile Site Key for authentication forms security
# Get one at: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_CLOUDFLARE_TURNSTILE_SITEKEY=your_cloudflare_turnstile_sitekey_here

# (Optional) Google OAuth Client ID for Google Sign-In integration
# Get one at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
