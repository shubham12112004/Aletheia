# Aletheia Backend Environment Variables

# AI & LLM Keys
# Required for LangChain models
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Financial Data Providers
# Used by the agents to fetch live market data
FINNHUB_API_KEY=your_finnhub_api_key_here
NEWS_API_KEY=your_news_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Database Config
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/aletheia

# Google OAuth Config
# For Google Login authentication
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Secret for Auth sessions
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudflare Turnstile Configuration
# Required for form protection
TURNSTILE_SITE_KEY=your_site_key_here
TURNSTILE_SECRET_KEY=your_secret_key_here

# Email Provider (Resend)
# Used for forgot password / OTP
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=Acme <onboarding@resend.dev>
RESEND_TO_OVERRIDE=

# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
